BINARY SEARCH

1. Classic Search

Template:

while(l <= r)
{
    int m =
        l + (r-l)/2;

    if(nums[m] == target)
        return m;

    if(nums[m] < target)
        l = m + 1;
    else
        r = m - 1;
}
2. Lower Bound

Template:

while(l < r)
{
    int m =
        l + (r-l)/2;

    if(nums[m] >= target)
        r = m;
    else
        l = m + 1;
}

